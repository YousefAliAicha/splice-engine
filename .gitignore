# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# Environments
.venv/
venv/
env/

# Secrets - never commit real API keys, .env.example is fine to commit
.env

# Model artifacts (regenerated by train.py, not committed - large, cheap to rebuild)
models/**/base_models.pkl
models/**/meta_learner.pkl
models/**/popularity_lists.pkl
models/**/knn.pkl
models/**/stat_features.pkl
models/**/eval_history.pkl
models/**/feature_importances.pkl
models/**/*.txt

# Content index and TMDB cache ARE committed - they took real API calls and
# embedding time to build, and without them "More like this" / hybrid mode
# don't work until someone reruns src/embeddings.py themselves
!models/**/content_index.faiss
!models/**/content_movie_ids.pkl
!models/**/content_embeddings.pkl
!models/tmdb_cache.json

# Feedback data (grows at runtime, keep sample only)
feedback/*.csv
!feedback/.gitkeep

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local notes - content gets posted as GitHub Issues manually, not committed as a file
ISSUES.md
